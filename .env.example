# Azure AI Foundry (LLM inference — uses unified v1 endpoint, no api_version needed)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Dataverse MCP Server (may be in a separate tenant)
MCP_SERVER_URL=https://your-org.crm.dynamics.com/api/mcp
MCP_AUTH_TOKEN=                  # Optional — if empty, device code flow will prompt you to sign in
MCP_TENANT_ID=                   # Target tenant ID for device code auth (optional, defaults to multi-tenant)

# Azure AI Foundry evaluation (optional)
AZURE_AI_CONNECTION_STRING=your_azure_ai_foundry_connection_string_here
